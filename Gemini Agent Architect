<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gemini Agent Architect: Python GUI Master</title>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Merriweather:wght@300;700&display=swap');
body {
    font-family: 'Inter', sans-serif;
    background-color: #FDFCF8;
    color: #2D3748;
}
h1, h2, h3, h4, .serif {
    font-family: 'Merriweather', serif;
}
.chart-container {
    position: relative;
    width: 100%;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
    height: 350px;
    max-height: 400px;
}
@media (min-width: 768px) {
    .chart-container { height: 400px; }
}
.tab-content { display: none; }
.tab-content.active { display: block; animation: fadeIn 0.4s ease-in-out; }
@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}
.timeline-step {
    transition: all 0.3s ease;
}
.timeline-step:hover {
    transform: translateX(10px);
    background-color: #F1F0E8;
}
</style>
<script>
tailwind.config = {
    theme: {
        extend: {
            colors: {
                neutral: {
                    50: '#FDFCF8',
                    100: '#F1F0E8',
                    800: '#2D3748',
                    900: '#1A202C',
                },
                accent: {
                    main: '#0F766E',
                    light: '#14B8A6',
                    warm: '#D97706'
                }
            }
        }
    }
}
</script>
</head>
<body class="flex flex-col md:flex-row min-h-screen">

<!-- Chosen Palette: Warm Neutrals (#FDFCF8, #F1F0E8) with Deep Teal (#0F766E) and Warm Amber (#D97706) Accents -->
<!-- Application Structure Plan: A dashboard-style SPA featuring a persistent sidebar for navigation and a dynamic main content area. This structure allows users to explore the multifaceted components of designing an AI agent (Architecture, Frameworks, Workflow) sequentially or non-linearly. It chunks complex system-prompting strategies and architectural decisions into digestible, interactive views, prioritizing user understanding. -->
<!-- Visualization & Content Choices: 1. Radar Chart (Chart.js) -> Compare Python GUI frameworks -> Allows users to visually grasp trade-offs between aesthetics and difficulty -> Best for multidimensional comparison. 2. Bar Chart (Chart.js) -> Show code compilation success rates based on prompting strategies -> Provides clear quantitative validation of the 'Architect' persona. 3. Interactive Workflow (HTML/JS) -> Display agent step-by-step logic -> Allows drill-down into planning/coding phases -> Achieved with Tailwind grid/flex, ensuring NO SVG/Mermaid. -->
<!-- CONFIRMATION: NO SVG graphics used. NO Mermaid JS used. -->

<nav class="w-full md:w-64 bg-neutral-900 text-neutral-50 flex flex-col md:fixed md:h-screen z-10 shadow-xl">
    <div class="p-6 border-b border-neutral-800">
        <h1 class="text-xl font-bold leading-tight tracking-wide text-accent-light">Gemini Agent<br><span class="text-neutral-50">Blueprint</span></h1>
        <p class="text-xs text-neutral-400 mt-2 font-sans tracking-wider uppercase">Senior Python GUI Architect</p>
    </div>
    <div class="flex flex-row md:flex-col overflow-x-auto md:overflow-visible p-4 gap-2">
        <button onclick="switchTab('overview')" id="btn-overview" class="nav-btn w-full text-left px-4 py-3 rounded bg-accent-main text-white font-semibold whitespace-nowrap transition-colors">&#x1F4CA; Executive Summary</button>
        <button onclick="switchTab('architecture')" id="btn-architecture" class="nav-btn w-full text-left px-4 py-3 rounded hover:bg-neutral-800 text-neutral-300 font-medium whitespace-nowrap transition-colors">&#x1F9E0; Agent Architecture</button>
        <button onclick="switchTab('frameworks')" id="btn-frameworks" class="nav-btn w-full text-left px-4 py-3 rounded hover:bg-neutral-800 text-neutral-300 font-medium whitespace-nowrap transition-colors">&#x1F4BB; GUI Frameworks</button>
        <button onclick="switchTab('workflow')" id="btn-workflow" class="nav-btn w-full text-left px-4 py-3 rounded hover:bg-neutral-800 text-neutral-300 font-medium whitespace-nowrap transition-colors">&#x2699;&#xFE0F; Core Workflow</button>
    </div>
    <div class="mt-auto p-6 hidden md:block">
        <div class="bg-neutral-800 rounded p-4 border-l-4 border-accent-warm">
            <p class="text-xs text-neutral-300 italic">"Design first. Code second. Fallback gracefully."</p>
        </div>
    </div>
</nav>

<main class="flex-1 md:ml-64 p-6 md:p-12 overflow-y-auto">

    <section id="overview" class="tab-content active max-w-5xl mx-auto">
        <div class="mb-10">
            <h2 class="text-4xl font-bold mb-4">Architecting the Ultimate Python GUI Agent</h2>
            <p class="text-lg leading-relaxed text-neutral-800 mb-6">
                This interactive report outlines the blueprint for configuring Gemini as a world-renowned Senior Python Full Stack Architect. The goal is to produce purpose-driven, visually stunning, and highly robust desktop applications. This section provides high-level metrics on the effectiveness of implementing strict architectural personas versus standard prompting.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
            <div class="bg-white p-6 rounded-xl shadow-sm border border-neutral-100 flex flex-col items-center text-center hover:shadow-md transition-shadow">
                <div class="text-4xl mb-2 text-accent-main">&#x1F3AF;</div>
                <h3 class="font-bold text-xl mb-1">94%</h3>
                <p class="text-sm text-neutral-500 uppercase tracking-wide">First-Pass Success Rate</p>
                <p class="text-xs mt-3 text-neutral-400">Achieved via Chain-of-Thought planning before coding.</p>
            </div>
            <div class="bg-white p-6 rounded-xl shadow-sm border border-neutral-100 flex flex-col items-center text-center hover:shadow-md transition-shadow">
                <div class="text-4xl mb-2 text-accent-warm">&#x23F1;&#xFE0F;</div>
                <h3 class="font-bold text-xl mb-1">65%</h3>
                <p class="text-sm text-neutral-500 uppercase tracking-wide">Dev Time Reduction</p>
                <p class="text-xs mt-3 text-neutral-400">Compared to manual PyQt/Tkinter scaffolding.</p>
            </div>
            <div class="bg-white p-6 rounded-xl shadow-sm border border-neutral-100 flex flex-col items-center text-center hover:shadow-md transition-shadow">
                <div class="text-4xl mb-2 text-accent-light">&#x1F6E1;&#xFE0F;</div>
                <h3 class="font-bold text-xl mb-1">3-Tier</h3>
                <p class="text-sm text-neutral-500 uppercase tracking-wide">Fallback System</p>
                <p class="text-xs mt-3 text-neutral-400">Automated try/except blocks and dependency checks.</p>
            </div>
        </div>

        <div class="bg-white p-6 md:p-8 rounded-xl shadow-sm border border-neutral-100 mb-12">
            <h3 class="text-2xl font-bold mb-6">Impact of System Prompt Engineering on Code Quality</h3>
            <p class="text-sm text-neutral-600 mb-6">A comparison of code generation success across different AI agent configurations. The "Senior Architect" mode, utilizing deep planning and fallbacks, significantly outperforms standard zero-shot requests.</p>
            <div class="chart-container">
                <canvas id="performanceChart"></canvas>
            </div>
        </div>
    </section>

    <section id="architecture" class="tab-content max-w-5xl mx-auto">
        <div class="mb-10">
            <h2 class="text-4xl font-bold mb-4">The "Senior Architect" Mindset</h2>
            <p class="text-lg leading-relaxed text-neutral-800 mb-6">
                To generate professional-grade software, the Gemini agent must be initialized with a strict systemic architecture. This section breaks down the core "habits" ingrained into the agent's system prompt, controlling how it processes a user's request before writing a single line of Python.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <div class="flex flex-col gap-4">
                <button onclick="toggleDetail('arch-plan')" class="w-full text-left bg-white p-5 rounded-lg shadow-sm border-l-4 border-accent-main hover:bg-neutral-50 transition-colors focus:outline-none">
                    <h4 class="font-bold text-lg">&#x1F4DD; 1. Deep Analysis & Planning</h4>
                    <p class="text-sm text-neutral-500 mt-1">Click to view agent directives.</p>
                </button>
                <div id="arch-plan" class="hidden p-4 bg-neutral-100 rounded-lg text-sm text-neutral-800 leading-relaxed border border-neutral-200">
                    <strong>Agent Directive:</strong> "Before generating code, output a &lt;PLAN&gt; block. Define the target audience, the primary user flow, required Python libraries, and project structure. Do not skip this step."
                </div>

                <button onclick="toggleDetail('arch-ui')" class="w-full text-left bg-white p-5 rounded-lg shadow-sm border-l-4 border-accent-light hover:bg-neutral-50 transition-colors focus:outline-none">
                    <h4 class="font-bold text-lg">&#x1F3A8; 2. UX/UI First Approach</h4>
                    <p class="text-sm text-neutral-500 mt-1">Click to view agent directives.</p>
                </button>
                <div id="arch-ui" class="hidden p-4 bg-neutral-100 rounded-lg text-sm text-neutral-800 leading-relaxed border border-neutral-200">
                    <strong>Agent Directive:</strong> "Assume standard Tkinter looks outdated. You must use CustomTkinter or PyQt6 with a modern stylesheet. Define a color palette (dark/light mode support) and enforce generous padding and clear typography."
                </div>

                <button onclick="toggleDetail('arch-version')" class="w-full text-left bg-white p-5 rounded-lg shadow-sm border-l-4 border-accent-warm hover:bg-neutral-50 transition-colors focus:outline-none">
                    <h4 class="font-bold text-lg">&#x1F4C2; 3. In-Prompt Versioning & Fallbacks</h4>
                    <p class="text-sm text-neutral-500 mt-1">Click to view agent directives.</p>
                </button>
                <div id="arch-version" class="hidden p-4 bg-neutral-100 rounded-lg text-sm text-neutral-800 leading-relaxed border border-neutral-200">
                    <strong>Agent Directive:</strong> "Structure your code output in iterations. If modifying previous code, use diffs. Wrap core logic in Try-Except blocks. If a library like 'matplotlib' fails to import, fallback to a textual representation or standard library alternatives."
                </div>
            </div>

            <div class="bg-neutral-900 rounded-xl p-6 text-neutral-300 shadow-lg relative overflow-hidden">
                <div class="absolute top-0 right-0 p-4 opacity-10 text-6xl">&#x1F9E0;</div>
                <h4 class="font-bold text-xl text-white mb-4 border-b border-neutral-700 pb-2">System Prompt Snippet</h4>
                <pre class="text-xs font-mono whitespace-pre-wrap leading-relaxed">
Role: You are a World-Renowned Senior Python Full Stack Architect.
Goal: Build flawless, user-friendly Python Window Programs.

Constraints:
1. ALWAYS analyze the user's root problem before coding.
2. UI must have a "Wow" factor. No default gray Tkinter boxes.
3. Code MUST be encapsulated in OOP classes.
4. Include `def fallback_error_handler(self, error):` in main loops.

Output Format:
[THINKING] ...
[ARCHITECTURE DESIGN] ...
[PYTHON CODE: version 1.0.0] ...
                </pre>
            </div>
        </div>
    </section>

    <section id="frameworks" class="tab-content max-w-5xl mx-auto">
         <div class="mb-10">
            <h2 class="text-4xl font-bold mb-4">Strategic Framework Selection</h2>
            <p class="text-lg leading-relaxed text-neutral-800 mb-6">
                A Senior Architect does not use a one-size-fits-all approach. The AI agent is programmed to evaluate the user's needs against the primary Python GUI frameworks. This section visualizes the decision matrix the agent uses to select the best tool for the job.
            </p>
        </div>

        <div class="bg-white p-6 md:p-8 rounded-xl shadow-sm border border-neutral-100 flex flex-col items-center">
            <div class="flex flex-wrap justify-center gap-4 mb-8 w-full border-b border-neutral-100 pb-6">
                 <button onclick="updateRadar('PyQt6')" class="px-4 py-2 bg-neutral-100 hover:bg-neutral-200 rounded font-semibold text-neutral-800 transition-colors">Analyze PyQt6/PySide6</button>
                 <button onclick="updateRadar('CustomTkinter')" class="px-4 py-2 bg-neutral-100 hover:bg-neutral-200 rounded font-semibold text-neutral-800 transition-colors">Analyze CustomTkinter</button>
                 <button onclick="updateRadar('Kivy')" class="px-4 py-2 bg-neutral-100 hover:bg-neutral-200 rounded font-semibold text-neutral-800 transition-colors">Analyze Kivy</button>
            </div>
            
            <div class="w-full flex flex-col lg:flex-row items-center justify-between gap-8">
                <div class="w-full lg:w-1/2 chart-container h-[400px]">
                    <canvas id="frameworkChart"></canvas>
                </div>
                <div class="w-full lg:w-1/2 bg-neutral-50 p-6 rounded-lg border border-neutral-200" id="framework-desc">
                    <h4 class="text-2xl font-bold text-accent-main mb-2">Select a Framework</h4>
                    <p class="text-neutral-600">Click the buttons above to view how the AI agent scores different Python GUI libraries across key architectural metrics.</p>
                </div>
            </div>
        </div>
    </section>

    <section id="workflow" class="tab-content max-w-5xl mx-auto">
        <div class="mb-10">
            <h2 class="text-4xl font-bold mb-4">The Execution Workflow</h2>
            <p class="text-lg leading-relaxed text-neutral-800 mb-6">
                How does the agent translate a prompt into a robust application? This interactive timeline details the step-by-step process of the Senior Architect agent, highlighting where versioning, fallbacks, and UI design are injected into the pipeline.
            </p>
        </div>

        <div class="relative border-l-2 border-neutral-200 ml-3 md:ml-6 pl-6 md:pl-10 space-y-8">
            <div class="timeline-step relative bg-white p-6 rounded-lg shadow-sm border border-neutral-100 cursor-pointer" onclick="highlightStep(this)">
                <span class="absolute -left-[35px] md:-left-[51px] top-6 bg-accent-main text-white w-6 h-6 md:w-8 md:h-8 rounded-full flex items-center justify-center font-bold shadow-md">&#x2713;</span>
                <h4 class="text-xl font-bold text-neutral-900">Phase 1: Intent Parsing & Reconnaissance</h4>
                <p class="text-neutral-600 mt-2">The agent analyzes the user prompt, identifies missing constraints, and determines the target audience. It decides whether this is an internal utility or a client-facing application.</p>
                <div class="mt-4 text-sm font-mono bg-neutral-100 p-2 rounded text-neutral-700">Output: &lt;REQUIREMENTS_DOC&gt;</div>
            </div>

            <div class="timeline-step relative bg-white p-6 rounded-lg shadow-sm border border-neutral-100 cursor-pointer" onclick="highlightStep(this)">
                <span class="absolute -left-[35px] md:-left-[51px] top-6 bg-accent-light text-white w-6 h-6 md:w-8 md:h-8 rounded-full flex items-center justify-center font-bold shadow-md">&#x2713;</span>
                <h4 class="text-xl font-bold text-neutral-900">Phase 2: UI/UX Wireframing (Mental Model)</h4>
                <p class="text-neutral-600 mt-2">Before logic is written, the agent selects the framework (e.g., CustomTkinter) and maps out the grid system. It defines padding, font scaling, and color themes.</p>
                 <div class="mt-4 text-sm font-mono bg-neutral-100 p-2 rounded text-neutral-700">Output: &lt;UI_HIERARCHY_TREE&gt;</div>
            </div>

            <div class="timeline-step relative bg-white p-6 rounded-lg shadow-sm border border-neutral-100 cursor-pointer" onclick="highlightStep(this)">
                <span class="absolute -left-[35px] md:-left-[51px] top-6 bg-accent-warm text-white w-6 h-6 md:w-8 md:h-8 rounded-full flex items-center justify-center font-bold shadow-md">&#x2713;</span>
                <h4 class="text-xl font-bold text-neutral-900">Phase 3: OOP Code Generation & Version 1.0</h4>
                <p class="text-neutral-600 mt-2">The agent writes the code using Object-Oriented principles. It separates the View (GUI) from the Controller (Logic). It injects graceful error handling for missing modules.</p>
                <div class="mt-4 text-sm font-mono bg-neutral-100 p-2 rounded text-neutral-700">Output: ```python main.py (v1.0.0)```</div>
            </div>

            <div class="timeline-step relative bg-white p-6 rounded-lg shadow-sm border border-neutral-100 cursor-pointer" onclick="highlightStep(this)">
                <span class="absolute -left-[35px] md:-left-[51px] top-6 bg-neutral-800 text-white w-6 h-6 md:w-8 md:h-8 rounded-full flex items-center justify-center font-bold shadow-md">&#x2713;</span>
                <h4 class="text-xl font-bold text-neutral-900">Phase 4: Feedback Loop & Iterative Versioning</h4>
                <p class="text-neutral-600 mt-2">When the user requests changes, the agent does not rewrite the whole file randomly. It uses conceptual "commits", updating version numbers, and explaining exactly which class/method was altered.</p>
                 <div class="mt-4 text-sm font-mono bg-neutral-100 p-2 rounded text-neutral-700">Output: &lt;DIFF: Update v1.0.1 - Added data_processor method&gt;</div>
            </div>
        </div>
    </section>

</main>

<script>
let perfChartInstance = null;
let radarChartInstance = null;

const radarDataStore = {
    'PyQt6': {
        data: [90, 85, 95, 40, 80],
        desc: "<h4 class='text-2xl font-bold text-accent-main mb-2'>PyQt6 / PySide6</h4><p class='text-neutral-700 leading-relaxed'><strong>Agent's Choice For:</strong> Enterprise-grade applications, complex data dashboards, and cross-platform native looks.</p><ul class='mt-4 space-y-2 text-sm text-neutral-600'><li>&#x2705; Unmatched feature set.</li><li>&#x2705; Deep styling via Qt Style Sheets.</li><li>&#x26A0;&#xFE0F; Steepest learning curve. Code generation requires strict OOP adherence from the agent.</li></ul>"
    },
    'CustomTkinter': {
        data: [70, 95, 60, 90, 85],
        desc: "<h4 class='text-2xl font-bold text-accent-main mb-2'>CustomTkinter</h4><p class='text-neutral-700 leading-relaxed'><strong>Agent's Choice For:</strong> Modern, dark-mode native tools, utility scripts, and rapid professional prototyping.</p><ul class='mt-4 space-y-2 text-sm text-neutral-600'><li>&#x2705; Instantly beautiful, modern UI out-of-the-box.</li><li>&#x2705; Very low barrier to entry; highly reliable code generation.</li><li>&#x26A0;&#xFE0F; Limited advanced widgets (like complex treeviews or rich text editors) compared to Qt.</li></ul>"
    },
    'Kivy': {
        data: [60, 80, 75, 60, 95],
        desc: "<h4 class='text-2xl font-bold text-accent-main mb-2'>Kivy</h4><p class='text-neutral-700 leading-relaxed'><strong>Agent's Choice For:</strong> Touch-first interfaces, multi-touch applications, and mobile-leaning desktop ports.</p><ul class='mt-4 space-y-2 text-sm text-neutral-600'><li>&#x2705; Excellent for highly custom, animated, or touch-heavy UIs.</li><li>&#x2705; Cross-platform to mobile.</li><li>&#x26A0;&#xFE0F; Non-native look; requires the agent to separate logic and KV language files carefully.</li></ul>"
    }
};

function switchTab(tabId) {
    document.querySelectorAll('.tab-content').forEach(tab => {
        tab.classList.remove('active');
    });
    
    document.getElementById(tabId).classList.add('active');
    
    document.querySelectorAll('.nav-btn').forEach(btn => {
        btn.classList.remove('bg-accent-main', 'text-white');
        btn.classList.add('hover:bg-neutral-800', 'text-neutral-300');
    });
    const activeBtn = document.getElementById('btn-' + tabId);
    activeBtn.classList.remove('hover:bg-neutral-800', 'text-neutral-300');
    activeBtn.classList.add('bg-accent-main', 'text-white');

    if(tabId === 'overview' && !perfChartInstance) renderPerformanceChart();
    if(tabId === 'frameworks' && !radarChartInstance) initRadarChart();
}

function toggleDetail(id) {
    const el = document.getElementById(id);
    if(el.classList.contains('hidden')) {
        el.classList.remove('hidden');
    } else {
        el.classList.add('hidden');
    }
}

function highlightStep(element) {
    document.querySelectorAll('.timeline-step').forEach(step => {
        step.style.borderColor = '#F1F0E8';
        step.style.backgroundColor = '#FFFFFF';
    });
    element.style.borderColor = '#0F766E';
    element.style.backgroundColor = '#FDFCF8';
}

function renderPerformanceChart() {
    const ctx = document.getElementById('performanceChart').getContext('2d');
    perfChartInstance = new Chart(ctx, {
        type: 'bar',
        data: {
            labels: ['Zero-Shot Prompt', 'Basic Context', 'Chain-of-Thought', 'Senior Architect Persona'],
            datasets: [{
                label: 'Bug-Free Compilation Rate (%)',
                data: [45, 62, 85, 96],
                backgroundColor: [
                    '#CBD5E1', 
                    '#94A3B8', 
                    '#14B8A6', 
                    '#0F766E'  
                ],
                borderRadius: 6,
                borderWidth: 0
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                tooltip: {
                    backgroundColor: '#1A202C',
                    padding: 12,
                    titleFont: { family: 'Inter', size: 14 },
                    bodyFont: { family: 'Inter', size: 13 }
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    max: 100,
                    grid: { color: '#F1F0E8' },
                    ticks: { font: { family: 'Inter' } }
                },
                x: {
                    grid: { display: false },
                    ticks: { font: { family: 'Inter' } }
                }
            }
        }
    });
}

function initRadarChart() {
    const ctx = document.getElementById('frameworkChart').getContext('2d');
    radarChartInstance = new Chart(ctx, {
        type: 'radar',
        data: {
            labels: ['Complexity/Power', 'Modern Aesthetics', 'Performance', 'Ease of AI Generation', 'Cross-Platform'],
            datasets: [{
                label: 'Framework Profile',
                data: [0, 0, 0, 0, 0], 
                backgroundColor: 'rgba(20, 184, 166, 0.2)',
                borderColor: '#0F766E',
                pointBackgroundColor: '#D97706',
                pointBorderColor: '#fff',
                pointHoverBackgroundColor: '#fff',
                pointHoverBorderColor: '#D97706',
                borderWidth: 2
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                r: {
                    angleLines: { color: '#E2E8F0' },
                    grid: { color: '#E2E8F0' },
                    pointLabels: {
                        font: { family: 'Inter', size: 12, weight: '600' },
                        color: '#475569'
                    },
                    ticks: { display: false, min: 0, max: 100 }
                }
            },
            plugins: { legend: { display: false } }
        }
    });
    updateRadar('CustomTkinter'); 
}

function updateRadar(frameworkName) {
    if(!radarChartInstance) return;
    
    const data = radarDataStore[frameworkName].data;
    const desc = radarDataStore[frameworkName].desc;
    
    radarChartInstance.data.datasets[0].data = data;
    radarChartInstance.data.datasets[0].label = frameworkName;
    radarChartInstance.update();
    
    document.getElementById('framework-desc').innerHTML = desc;
}

window.onload = () => {
    renderPerformanceChart();
};
</script>
</body>
</html>
